<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF1A1A2E">

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Disconnected"
        android:textColor="#FF888888"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_margin="8dp" />

    <EditText
        android:id="@+id/addressInput"
        android:layout_width="150dp"
        android:layout_height="40dp"
        android:hint="Server IP"
        android:textColor="#FFFFFFFF"
        android:textColorHint="#FF666666"
        android:background="#FF2D2D44"
        android:padding="8dp"
        android:inputType="phone"
        android:gravity="center"
        app:layout_constraintEnd_toStartOf="@id/portInput"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="8dp" />

    <EditText
        android:id="@+id/portInput"
        android:layout_width="80dp"
        android:layout_height="40dp"
        android:hint="Port"
        android:textColor="#FFFFFFFF"
        android:textColorHint="#FF666666"
        android:background="#FF2D2D44"
        android:padding="8dp"
        android:inputType="number"
        android:gravity="center"
        android:text="42069"
        app:layout_constraintEnd_toStartOf="@id/connectBtn"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="8dp" />

    <Button
        android:id="@+id/connectBtn"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:text="Connect"
        android:textSize="12sp"
        android:backgroundTint="#FF0F3460"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp" />

    <com.controllers.app.GamepadView
        android:id="@+id/gamepadView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/statusText"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
